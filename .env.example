# Groq (default): https://console.groq.com/keys — use either name for the same bearer token
# Same key powers Whisper STT in Conversation when `LLM_BASE_URL` points at Groq, or set explicitly:
GROQ_API_KEY=
# LLM_API_KEY=

# Optional — Groq OpenAI-compatible root + a fast default model (change LLM_MODEL anytime)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# Other model ids: llama-3.1-8b-instant, openai/gpt-oss-120b, openai/gpt-oss-20b, qwen/qwen3-32b, …
# List: https://api.groq.com/openai/v1/models (GET with your key) or https://console.groq.com/docs/models

# OpenAI instead: set both explicitly, e.g.
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Set to false if your provider rejects response_format json_object
# LLM_JSON_OBJECT=true

# Google OAuth (Auth.js) — required for /app and API routes. Create OAuth client at
# https://console.cloud.google.com/apis/credentials — Authorized redirect URI:
#   http://localhost:5173/auth/callback/google   (dev; add your production URL too)
# AUTH_SECRET: random string, 32+ characters (e.g. openssl rand -base64 32)
AUTH_SECRET=
PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional for most hosts; set true on Netlify/Cloudflare etc. if sign-in URLs fail.
# AUTH_TRUST_HOST=true

# PocketBase — server-only admin API (sync `peoples` on Google OAuth). No trailing slash.
# In production, set all three and set POCKETBASE_REQUIRED=true so trial gating cannot be skipped.
# POCKETBASE_URL=
# POCKETBASE_ADMIN_EMAIL=
# POCKETBASE_ADMIN_PASSWORD=
# POCKETBASE_REQUIRED=false

# Path to the waitlist signup log (JSONL). Defaults to ./data/waitlist.jsonl
# locally and /app/data/waitlist.jsonl in the Docker image — mount a persistent
# volume at /app/data in EasyPanel so signups survive redeploys.
# WAITLIST_FILE=/app/data/waitlist.jsonl

# German TTS via Piper (Thorsten medium voice). The Docker image starts a
# local Piper HTTP server at 127.0.0.1:5000 and points PIPER_TTS_URL there.
# In local dev you can either:
#   - leave it unset → /api/tts errors and the client falls back to browser TTS
#   - run piper yourself: `pip install 'piper-tts[http]' &&
#       python -m piper.download_voices de_DE-thorsten-medium &&
#       python -m piper.http_server -m de_DE-thorsten-medium`
#     and point this at it.
# PIPER_TTS_URL=http://127.0.0.1:5000
