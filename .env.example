# Groq (default): https://console.groq.com/keys — use either name for the same bearer token
GROQ_API_KEY=
# LLM_API_KEY=

# Optional — Groq OpenAI-compatible root + a fast default model (change LLM_MODEL anytime)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# Other model ids: llama-3.1-8b-instant, openai/gpt-oss-120b, openai/gpt-oss-20b, qwen/qwen3-32b, …
# List: https://api.groq.com/openai/v1/models (GET with your key) or https://console.groq.com/docs/models

# OpenAI instead: set both explicitly, e.g.
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# Set to false if your provider rejects response_format json_object
# LLM_JSON_OBJECT=true
